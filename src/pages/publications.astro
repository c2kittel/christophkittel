---
import BaseLayout from '../layouts/BaseLayout.astro';
import { publications } from '../data/publications.js';

// On définit tes 5 publications majeures (Highlights)
const highlightedDOIs = [
  "10.5194/tc-15-1215-2021",  // Diverging SMB
  "10.5194/tc-16-2655-2022",  // Clouds
  "10.5194/tc-19-4459-2025",  // Greenland 200 years
  "10.1038/s41586-025-09657-w" // Nature 2025
];

const highlights = publications.filter(p => highlightedDOIs.includes(p.doi));

// Inversion de la liste pour l'affichage (Plus récent en haut)
const latestFirst = [...publications].reverse();
---

<BaseLayout title="Publications | Christoph Kittel">
  <main class="max-w-5xl mx-auto p-8">
    <header class="mb-16 mt-8">
      <h1 class="text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">Publications</h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Full list of peer-reviewed articles and key research contributions in polar climate and glaciology.
      </p>
    </header>

    <section class="mb-24">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-2xl font-bold text-blue-900 uppercase tracking-wider text-sm">Selected Highlights</h2>
        <div class="h-px flex-1 bg-blue-100"></div>
      </div>
      
      <div class="grid gap-8">
        {highlights.map(pub => (
          <div class="group relative bg-white border border-blue-100 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16" viewBox="0 0 24 24"><path fill="currentColor" d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m-7 14H7v-2h5v2m5-4H7v-2h10v2m0-4H7V7h10v2Z"/></svg>
            </div>
            <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold mb-4">{pub.year}</span>
            <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-700 transition-colors">{pub.title}</h3>
            <p class="text-gray-500 mb-6 italic">{pub.journal}</p>
        <div class="flex gap-6">
  		<a href={pub.link} target="_blank" class="text-sm font-bold text-blue-600 hover:text-blue-800 flex items-center gap-2">
    		DOI / Article
  		  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
 	 </a>	

  		<a href={`/publications/${pub.doi.replaceAll('/', '-')}`} class="text-sm font-bold text-gray-900 hover:text-blue-700 flex items-center gap-2 transition-colors">
    Read Summary →
  		</a>
     		</div>  
	</div>
        ))}
      </div>
    </section>

    <section>
      <div class="flex items-center gap-4 mb-12">
        <h2 class="text-2xl font-bold text-gray-800 uppercase tracking-wider text-sm">Full Publication List</h2>
        <div class="h-px flex-1 bg-gray-100"></div>
      </div>

      <div class="space-y-10">
        {latestFirst.map((pub, index) => (
          <div class="flex gap-8 group">
            <div class="flex-none w-12 pt-1 text-right">
              <span class="text-2xl font-black text-gray-200 group-hover:text-blue-200 transition-colors tabular-nums">
                {(latestFirst.length - index).toString().padStart(2, '0')}
              </span>
            </div>
            <div class="flex-1">
              <p class="text-lg font-bold text-gray-900 leading-snug mb-2 group-hover:text-blue-900 transition-colors">
                {pub.title}
              </p>
              <p class="text-sm text-gray-600 mb-3 leading-relaxed">
                {/* On met ton nom en gras dans la liste des auteurs */}
                {pub.authors.split(', ').map((author, i, arr) => (
                  <span>
                    {author.includes('Kittel') ? <strong class="text-gray-900">{author}</strong> : author}
                    {i < arr.length - 1 ? ', ' : ''}
                  </span>
                ))}
              </p>
              <div class="flex items-center gap-3">
                <span class="text-xs font-bold px-2 py-0.5 bg-gray-100 text-gray-700 rounded uppercase tracking-tighter">
                  {pub.year}
                </span>
                <span class="text-xs text-blue-600 font-medium italic">
                  {pub.journal}
                </span>
                <a href={pub.link} target="_blank" class="text-xs text-gray-400 hover:text-blue-600 underline ml-auto transition-colors">
                  View Source
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Pour l'effet de soulignement progressif au survol */
  .tabular-nums {
    font-variant-numeric: tabular-nums;
  }
</style>
