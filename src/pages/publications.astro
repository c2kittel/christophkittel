---
import BaseLayout from '../layouts/BaseLayout.astro';
import pubs from '../data/publications.json';

// Trier les publications par année (décroissant)
const sortedPubs = pubs.sort((a, b) => b.year - a.year);
const years = [...new Set(sortedPubs.map(p => p.year))];
---

<BaseLayout title="Publications">
  <div class="max-w-4xl mx-auto">
    <header class="mb-12">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-slate-950 mb-4">Publications</h1>
      <p class="text-slate-600">
        Automatically synchronized with my <a href="https://orbi.uliege.be/phid/u223159" class="text-blue-700 hover:underline" target="_blank">Orbi profile</a>.
      </p>
    </header>

    <div class="space-y-12">
      {years.map(year => (
        <section class="relative">
          <div class="sticky top-20 bg-slate-50/90 backdrop-blur-sm py-2 z-10 border-b border-slate-200 mb-6">
            <h2 class="font-serif text-2xl font-bold text-blue-900">{year}</h2>
          </div>
          
          <ul class="space-y-6">
            {sortedPubs.filter(p => p.year === year).map(pub => (
              <li class="group">
                <div class="p-5 bg-white rounded-xl border border-slate-100 shadow-sm hover:shadow-md hover:border-blue-200 transition-all">
                  <p class="text-slate-800 leading-snug mb-3" set:html={pub.fullReference}></p>
                  
                  {pub.doi && (
                    <a 
                      href={pub.doi} 
                      target="_blank" 
                      class="inline-flex items-center text-xs font-bold text-blue-600 uppercase tracking-widest hover:text-blue-800 transition"
                    >
                      View Publication
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
