---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 1. Récupérer et trier les news (Date la plus récente en premier)
const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="News | Christoph Kittel">
  <main class="max-w-4xl mx-auto p-8 py-16">
    <header class="mb-16">
      <h1 class="text-5xl font-black text-slate-900 mb-4 italic">News</h1>
      <p class="text-blue-600 font-bold uppercase tracking-widest text-sm">Updates from the field and the lab</p>
    </header>

    <div class="space-y-16">
      {sortedNews.map(news => (
        <article class="group relative grid md:grid-cols-4 gap-8 items-start">
          <div class="md:col-span-1">
            <time class="text-sm font-mono text-slate-400 block mb-2">
              {news.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {news.data.relatedProject && (
              <span class="inline-block px-2 py-1 bg-blue-50 text-blue-600 text-[10px] font-black uppercase tracking-tighter rounded border border-blue-100">
                Project: {news.data.relatedProject.replace(/-/g, ' ')}
              </span>
            )}
          </div>

          <div class="md:col-span-3 space-y-4">
            <h2 class="text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-tight">
              <a href={`/news/${news.slug}`}>{news.data.title}</a>
            </h2>
            <p class="text-slate-600 leading-relaxed">
              {news.data.summary}
            </p>
            <a href={`/news/${news.slug}`} class="inline-flex items-center text-sm font-bold text-slate-900 group-hover:gap-3 gap-2 transition-all italic">
              Read more <span class="text-blue-600">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
