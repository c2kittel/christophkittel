---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects.js';

const ongoing = projects.filter(p => p.status === 'ongoing');
const past = projects.filter(p => p.status === 'past');
---

<BaseLayout title="Projects | Christoph Kittel">
  <main class="max-w-6xl mx-auto p-8 py-16">
    <header class="mb-16">
      <h1 class="text-5xl font-black text-slate-900 mb-4 italic">Projects</h1>
      <p class="text-blue-600 font-bold uppercase tracking-widest text-sm">Ongoing Research & Past Contributions</p>
    </header>

    <section class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-2xl font-bold text-slate-900">Active Research</h2>
        <div class="h-px flex-1 bg-blue-100"></div>
        <span class="px-3 py-1 bg-blue-600 text-white text-xs font-black rounded-full uppercase tracking-tighter">Current</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {ongoing.map(p => (
          <a href={`/projects/${p.id}`} class="group relative bg-white border border-slate-200 p-8 rounded-3xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
            {/* Rôle Badge */}
            <div class={`absolute top-6 right-6 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest ${p.role === 'PI' || p.role === 'Co-PI' ? 'bg-orange-100 text-orange-700 border border-orange-200' : 'bg-slate-100 text-slate-600'}`}>
              {p.role}
            </div>
            
            <p class="text-blue-600 font-mono text-xs mb-4">{p.period} • {p.funding}</p>
            <h3 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-blue-700 transition-colors">{p.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 line-clamp-2">{p.summary}</p>
            
            <div class="flex items-center text-sm font-bold text-slate-900">
              View Project Details <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section>
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-2xl font-bold text-slate-900">Past Projects</h2>
        <div class="h-px flex-1 bg-slate-100"></div>
      </div>

      <div class="space-y-4">
        {past.map(p => (
          <a href={`/projects/${p.id}`} class="flex flex-col md:flex-row md:items-center gap-4 p-6 bg-slate-50/50 hover:bg-white border border-transparent hover:border-slate-200 rounded-2xl transition-all group">
            <span class="text-xs font-mono text-slate-400 w-32">{p.period}</span>
            <div class="flex-1">
              <h3 class="font-bold text-slate-800 group-hover:text-blue-600 transition-colors">{p.title}</h3>
              <p class="text-xs text-slate-500 uppercase font-bold mt-1">{p.role} — {p.funding}</p>
            </div>
            <span class="text-slate-300 group-hover:text-blue-600 transition-colors">→</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
