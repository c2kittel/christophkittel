---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cvData } from '../data/cv.js';
---

<BaseLayout title="CV | Christoph Kittel">
  <main class="max-w-4xl mx-auto p-8 py-16">
    <header class="mb-16 border-b pb-8">
      <h1 class="text-5xl font-black text-gray-900 mb-4">Curriculum Vitae</h1>
      <p class="text-blue-600 font-bold text-lg uppercase tracking-widest leading-tight">
        Scientific Experience & Academic Service
      </p>
    </header>

    <section class="mb-20">
      <h2 class="text-sm font-black text-gray-400 uppercase tracking-[0.2em] mb-8 flex items-center gap-4">
        Scientific Experience <div class="h-px flex-1 bg-gray-100"></div>
      </h2>
      <div class="space-y-12">
        {cvData.experience.map(job => (
          <div class="relative pl-8 border-l-2 border-blue-100">
            <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white border-2 border-blue-600"></div>
            <h3 class="text-xl font-bold text-gray-900">{job.institution}</h3>
            <div class="mt-4 space-y-4">
              {job.roles.map(role => (
                <div class="flex flex-col md:flex-row md:justify-between md:items-baseline">
                  <span class="font-semibold text-gray-700 italic">{role.title}</span>
                  <span class="text-sm font-mono text-gray-400">{role.period}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="grid md:grid-cols-2 gap-16 mb-20">
      <section>
        <h2 class="text-sm font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Teaching</h2>
        <div class="space-y-8">
          {cvData.teaching.map(section => (
            <div>
              <p class="text-xs font-bold text-blue-600 mb-3 uppercase tracking-tighter">{section.type} • {section.institution}</p>
              <ul class="space-y-4">
                {section.courses.map(course => (
                  <li>
                    <a href={course.link} target="_blank" class="group block">
                      <p class="text-sm font-bold text-gray-800 group-hover:text-blue-700 transition-colors">
                        {course.name}
                        <svg xmlns="http://www.w3.org/2000/svg" class="inline w-3 h-3 ml-1 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                      </p>
                      <p class="text-xs font-mono text-gray-400">{course.code}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-sm font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Supervision</h2>
        <ul class="space-y-4 text-sm text-gray-700">
          <li class="flex items-start gap-3">
            <span class="text-blue-600 font-bold">•</span>
            <span><strong>2 PhD Students</strong><br/><span class="text-gray-500 text-xs uppercase font-bold">Main Supervisor — ULiège</span></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600 font-bold">•</span>
            <span><strong>2 PhD Committees</strong><br/><span class="text-gray-500 text-xs uppercase font-bold">1 ULiège, 1 VUB</span></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-600 font-bold">•</span>
            <span><strong>Graduate Students</strong><br/><span class="text-gray-500 text-xs uppercase font-bold">Master & Bachelor supervision (ULiège/VUB)</span></span>
          </li>
        </ul>
      </section>
    </div>

    <div class="grid md:grid-cols-2 gap-16">
       <section>
        <h2 class="text-sm font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Education</h2>
        <div class="space-y-8">
          {cvData.education.map(edu => (
            <div>
              <p class="font-bold text-gray-900 leading-tight">{edu.degree}</p>
              <p class="text-sm text-gray-500">{edu.institution} | {edu.period}</p>
              {edu.mention && <p class="text-[10px] font-black text-blue-500 mt-1 uppercase tracking-widest">{edu.mention}</p>}
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-sm font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Honors & Awards</h2>
        <div class="space-y-8">
          {cvData.awards.map(award => (
            <div>
              <div class="flex justify-between items-baseline mb-1">
                <p class="font-bold text-gray-900 leading-tight">{award.title}</p>
                <span class="text-xs font-mono text-gray-400 ml-2">{award.year}</span>
              </div>
              <p class="text-xs text-blue-600 font-bold mb-1 uppercase tracking-tighter">{award.provider}</p>
              <p class="text-sm text-gray-600 leading-snug italic">{award.desc}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</BaseLayout>