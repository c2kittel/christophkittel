---
const { title } = Astro.props;
import '../styles/global.css';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Christoph Kittel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans leading-relaxed">
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="font-serif text-xl font-bold tracking-tight">Christoph Kittel</a>
        <div class="space-x-8 text-sm font-medium uppercase tracking-wider text-slate-600">
          <a href="/" class="hover:text-blue-700 transition">Home</a>
          <a href="/cv" class="hover:text-blue-700 transition">CV</a>
          <a href="/publications" class="hover:text-blue-700 transition">Publications</a>
          <a href="/projects" class="hover:text-blue-700 transition">Projects</a>
          <a href="/students" class="hover:text-blue-700 transition">Students</a>
          <a href="/news" class="hover:text-blue-700 transition">News</a>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-slate-200 mt-20 py-10 text-center text-sm text-slate-500">
      <p>© {new Date().getFullYear()} — Christoph Kittel. Built with Astro.</p>
    </footer>
  </body>
</html>
